!
router bgp 65001
 bgp router-id 192.168.1.1
 neighbor 192.168.1.2 remote-as 65002
 neighbor 192.168.1.2 description UpdatedPeer
 neighbor 192.168.1.3 remote-as 65003
 address-family ipv4 unicast
  network 10.0.0.0/24
  network 10.0.2.0/24
 exit-address-family
exit
!
interface Ethernet0
 ip address 192.168.1.1/24
 description Primary
exit
! 